<?xml version="1.0" encoding="utf-8" ?>
<Override>
  <Afflictions>
    <!-- Liver Damage. Visible on Health Scanner. Causes: Liver Failure if severe enough -->
    <Affliction
      name=""
      description=""
      identifier="liverdamage"
      
      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"

      showinhealthscannerthreshold="20"
      showiconthreshold="999"
      maxstrength="100">

      <icon texture="Content/UI/MainIconsAtlas.png" sourcerect="128,384,128,128" color="195,136,60,255" origin="0,0"/>
    </Affliction>

    <!-- Liver Removed. Visible in Health UI and Scanner. Causes: Liver Failure -->
    <Affliction
      name=""
      description=""
      identifier="liverremoved"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"
      iconcolors="84,211,211,255;84,211,211,255"

      showinhealthscannerthreshold="0"
      showiconthreshold="50"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="0,5" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- Liver Swap. Visible in Health UI and Scanner. Used for Organ Transplant Surgery. -->
    <Affliction
      name=""
      description=""
      identifier="liverswap"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"
      iconcolors="84,211,211,255;84,211,211,255"

      showinhealthscannerthreshold="0"
      showiconthreshold="50"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons2.png" sheetindex="0,5" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>
  </Afflictions>
</Override>