<?xml version="1.0" encoding="utf-8" ?>
<Override>
  <Afflictions>

    <!-- Luabotomy: Calculations are only ran on humans with Luabotomy + used to show faulty Lua installs. -->
    <Affliction
      name=""
      identifier="luabotomy"
      description=""
      limbspecific="false"
      indicatorlimb="Head"
      showiconthreshold="14"
      showinhealthscannerthreshold="100"
      maxstrength="15"
      targets="human"
      type="gaze"
      isbuff="false"
      healableinmedicalclinic="false"
      iconcolors="255,255,255,255;255,255,255,255">

      <Effect minstrength="0" maxstrength="15" strengthchange="1" />

      <icon texture="%ModDir%/Images/AfflictionIcons2.png" sheetindex="5,0" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- LuabotomyPurger: Instantly removes all Luabotomy strength. -->
    <Affliction
      name=""
      identifier="luabotomypurger"
      description=""
      limbspecific="false"
      indicatorlimb="Head"
      showiconthreshold="100"
      showinhealthscannerthreshold="100"
      maxstrength="2"
      targets="human"
      type="gaze"
      isbuff="false"
      healableinmedicalclinic="false"
      iconcolors="255,255,255,255;255,255,255,255">

      <Effect minstrength="0" maxstrength="2" strengthchange="-1">
        <StatusEffect target="Character" multiplyafflictionsbymaxvitality="true">
          <conditional ishuman="true"/>
          <ReduceAffliction identifier="luabotomy" amount="100" />
        </StatusEffect>
      </Effect>

      <icon texture="%ModDir%/Images/AfflictionIcons2.png" sheetindex="5,0" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- StopCreatureAbuse: Used to reduce damage taken from certain creatures who would break FallDamage calculations. -->
    <Affliction
      name=""
      identifier="stopcreatureabuse"
      description=""
      limbspecific="false"
      showiconthreshold="100"
      showinhealthscannerthreshold="100"
      maxstrength="2"
      targets="human"
      isbuff="false"
      healableinmedicalclinic="false"
      iconcolors="255,255,255,255;255,255,255,255">

      <Effect minstrength="0" maxstrength="2" strengthchange="-0.5"/>

      <icon texture="%ModDir%/Images/AfflictionIcons2.png" sheetindex="7,0" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- ModConflict: Applied when the ModConflict.lua script detects conflicts in XML data for specific items. -->
    <Affliction
