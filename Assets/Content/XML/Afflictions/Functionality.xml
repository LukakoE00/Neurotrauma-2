          <TriggerAnimation Type="Crouch" path="%ModDir%\Characters\Human\Animations\HumanProneCrouch.xml" priority="10" ExpectedSpecies="Human" />
          <TriggerAnimation Type="Walk" path="%ModDir%\Characters\Human\Animations\HumanProneWalkProperBowthWays.xml" priority="10" ExpectedSpecies="Human" />
          <TriggerAnimation Type="Run" path="%ModDir%\Characters\Human\Animations\HumanProneRunProperBowthWays.xml" priority="10" ExpectedSpecies="Human" />
