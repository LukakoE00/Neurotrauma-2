<?xml version="1.0" encoding="utf-8" ?>
<Override>
  <Afflictions>
    <!-- Bone Damage. Visible on Health Scanner. Causes: Bone Death if severe enough. -->
    <Affliction
      name=""
      description=""
      identifier="bonedamage"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"

      showinhealthscannerthreshold="20"
      showiconthreshold="999"
      maxstrength="100">

