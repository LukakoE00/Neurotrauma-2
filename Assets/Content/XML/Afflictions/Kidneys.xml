<?xml version="1.0" encoding="utf-8" ?>
<Override>
  <Afflictions>
    <!-- Kidney Damage. Visible on Scanner. Causes: Kidney Failure (both kidneys dead) if severe enough. -->
    <Affliction
      name=""
      description=""
      identifier="kidneydamage"
      
      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"

      showinhealthscannerthreshold="10"
      showiconthreshold="999"
      maxstrength="100">

      <icon texture="Content/UI/MainIconsAtlas.png" sourcerect="128,384,128,128" color="195,136,60,255" origin="0,0"/>
    </Affliction>

    <!-- Kidneys removed. Visible in Health UI and Scanner. Causes: Kidney Failure (both kidneys dead). -->
    <Affliction
      name=""
      description=""
      identifier="kidneyremoved"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"
      iconcolors="84,211,211,255;84,211,211,255"

      showinhealthscannerthreshold="0"
      showiconthreshold="50"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="2,5" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- Kidney Swap. Visible in Health UI and Scanner. Used for Organ Transplant Surgery. -->
    <Affliction
      name=""
      description=""
      identifier="kidneyswap"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"
      iconcolors="84,211,211,255;84,211,211,255"

      showinhealthscannerthreshold="0"
      showiconthreshold="50"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons2.png" sheetindex="2,5" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>
  </Afflictions>
</Override>