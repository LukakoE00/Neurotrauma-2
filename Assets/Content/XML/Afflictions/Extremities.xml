        minvitalitydecrease="0"
        maxvitalitydecrease="15"/>

      <Effect minstrength="50" maxstrength="100"
        minvitalitydecrease="15"
        maxvitalitydecrease="25"/>

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="6,3" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

