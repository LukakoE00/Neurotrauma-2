    <!-- Gangrene / Cell death caused by cut off bloodflow. Visible in Health UI and Scanner. Causes: Sepsis. Requires Amputation above 15%. -->
    <Affliction
      name=""
      identifier="gangrene"
      description=""
      healableinmedicalclinic="false"
      type="gaze"
      isbuff="false"
      targets="human"
      limbspecific="True"
      showinhealthscannerthreshold="1"
      showiconthreshold="15"
      maxstrength="100"
      iconcolors="200,0,0,255;200,0,0,255;200,0,0,255">

