<?xml version="1.0" encoding="utf-8" ?>
<Override>
  <Afflictions>
    <!-- Respiratory Arrest / Apnea. Visible in Health UI. Causes: Oxygen Low. -->
    <Affliction
      name=""
      description=""
      identifier="respiratoryarrest"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"
      causespeechimpediment="true"

      showinhealthscannerthreshold="999"
      showiconthreshold="0"
      maxstrength="100">

      <Effect minstrength="0" maxstrength="2">
              <StatusEffect target="Character" speechimpediment="100"/>
      </Effect>

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="3,0" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- Hyperventilation. Symptom. Visible in Health UI. Causes: Alkalosis. -->
    <Affliction
      name=""
      description=""
      identifier="hyperventilation"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"
      iconcolors="255,90,0,255;255,90,0,255"
      
      showinhealthscannerthreshold="999"
      showiconthreshold="0"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="4,0" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- Hypoventilation. Symptom. Visible in Health UI. Causes: Acidosis. -->
    <Affliction
      name=""
      description=""
      identifier="hypoventilation"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"
      iconcolors="255,90,0,255;255,90,0,255"
      
      showinhealthscannerthreshold="999"
      showiconthreshold="0"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="5,0" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- Dyspnea / Shortness of Breath. Symptom. Visible in Health UI. -->
    <Affliction
      name=""
      description=""
      identifier="shortnessofbreath"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"
      iconcolors="255,90,0,255;255,90,0,255"
      
      showinhealthscannerthreshold="999"
      showiconthreshold="0"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="6,0" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- Pneumothorax / Collapsed Lung. Visible on Health Scanner. Causes: Shortness of Breath, Tachycardia / Increased Heartrate, Hyperventilation, Hypotension and Chest Pain. -->
    <Affliction
      name=""
      description=""
      identifier="pneumothorax"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="False"
      indicatorlimb="Torso"

      showinhealthscannerthreshold="0"
      showiconthreshold="999"
      maxstrength="100">

      <icon texture="Content/UI/MainIconsAtlas.png" sourcerect="896,896,128,128" color="195,136,60,255" origin="0,0"/>
    </Affliction>

    <!-- Lung Damage. Visible on Health Scanner. Causes: Shortness of Breath, Chest Pain, Cough, Hypoxemia and leads to Respiratory Arrest if severe enough. -->
    <Affliction
      name=""
      description=""
      identifier="lungdamage"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"

      showinhealthscannerthreshold="20"
      showiconthreshold="999"
      maxstrength="100">

      <icon texture="Content/UI/MainIconsAtlas.png" sourcerect="128,384,128,128" color="195,136,60,255" origin="0,0"/>
    </Affliction>

    <!-- Lungs removed. Visible in Health UI and Scanner. Causes: Respiratory Arrest. -->
    <Affliction
      name=""
      description=""
      identifier="lungremoved"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"
      iconcolors="84,211,211,255;84,211,211,255"
      
      showinhealthscannerthreshold="0"
      showiconthreshold="50"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="1,5" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- Lung Replacement. Visible in Health UI and Scanner. Used for Organ Transplant Surgery. -->
    <Affliction
      name=""
      description=""
      identifier="lungswap"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"
      iconcolors="84,211,211,255;84,211,211,255"

      showinhealthscannerthreshold="0"
      showiconthreshold="50"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons2.png" sheetindex="1,5" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>
  </Afflictions>
</Override>