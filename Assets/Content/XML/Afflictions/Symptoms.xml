    <!-- As a rule of thumb, Symptoms visible in the Health UI aren't visible on the Scanner to reduce clutter. -->

    <!-- Cough. Visible in Health UI. -->
    <Affliction
      name=""
      identifier="sym_cough"
      description=""
      healableinmedicalclinic="false"
      type="gaze"
      isbuff="false"
      limbspecific="false"
      indicatorlimb="Head"
      showiconthreshold="1"
      showinhealthscannerthreshold="100"
      maxstrength="2"
      iconcolors="255,90,0,255;255,90,0,255">

      <PeriodicEffect mininterval="12" maxinterval="26">

        <StatusEffect target="Character" comparison="and">
          <Conditional ishuman="true" />
          <Conditional ismale="true"/>
          <Conditional sym_cough="gte 1"/>
          <Sound file="%ModDir%/Sound/Voice/male_cough1.ogg" selectionmode="Random" />
          <Sound file="%ModDir%/Sound/Voice/male_cough2.ogg" />
          <Sound file="%ModDir%/Sound/Voice/male_cough3.ogg" />
          <Sound file="%ModDir%/Sound/Voice/male_cough4.ogg" />
        </StatusEffect>

        <StatusEffect target="Character" comparison="and">
          <Conditional ishuman="true" />
          <Conditional isfemale="true"/>
          <Conditional sym_cough="gte 1"/>
          <Sound file="%ModDir%/Sound/Voice/female_cough1.ogg" selectionmode="Random" />
          <Sound file="%ModDir%/Sound/Voice/female_cough2.ogg" />
          <Sound file="%ModDir%/Sound/Voice/female_cough3.ogg" />
          <Sound file="%ModDir%/Sound/Voice/female_cough4.ogg" />
          <Sound file="%ModDir%/Sound/Voice/female_cough5.ogg" />
          <Sound file="%ModDir%/Sound/Voice/female_cough6.ogg" />
        </StatusEffect>

      </PeriodicEffect>

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="7,0" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

